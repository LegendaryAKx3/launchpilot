# Web Auth0 config (required for sign in)
APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
AUTH0_AUDIENCE=https://api.growthlaunchpad.app
AUTH0_SCOPE=openid profile email project:read project:write research:run positioning:run execution:run approval:read approval:write execution:send

# Optional aliases
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API endpoint used by web
API_BASE_URL=http://localhost:8000/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/v1

# Optional realtime
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

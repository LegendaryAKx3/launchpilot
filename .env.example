# ==========================================================
# Web
# ==========================================================
# Required
API_BASE_URL=http://localhost:8000/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/v1

# Required only when enabling Auth0 web login
APP_BASE_URL=http://localhost:3000
AUTH0_SECRET=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Optional
AUTH0_AUDIENCE=
AUTH0_SCOPE=openid profile email offline_access
AUTH0_BASE_URL=
AUTH0_ISSUER_BASE_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================================
# API
# ==========================================================
# Required
SUPABASE_DB_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
WEB_APP_URL=http://localhost:3000
AUTH_MODE=dev

# Required when AUTH_MODE=auth0
AUTH0_ISSUER=
AUTH0_AUDIENCE=
APP_JWT_NAMESPACE=https://growthlaunchpad.app

# Optional: use real sending when key is present
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@growthlaunchpad.app

# Required for Backboard-powered agent pipeline
BACKBOARD_API_KEY=

# Optional Backboard overrides
BACKBOARD_BASE_URL=https://app.backboard.io/api
BACKBOARD_LLM_PROVIDER=openai
BACKBOARD_MODEL_NAME=gpt-4o
BACKBOARD_MEMORY_MODE=Auto

# ==========================================================
# Web
# ==========================================================
# Required
NEXT_PUBLIC_APP_URL=
APP_BASE_URL=
AUTH0_SECRET=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
API_BASE_URL=
NEXT_PUBLIC_API_BASE_URL=

# Optional (legacy aliases / defaults)
AUTH0_BASE_URL=
AUTH0_ISSUER_BASE_URL=
AUTH0_SCOPE=openid profile email offline_access
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ==========================================================
# API
# ==========================================================
# Required for local/runtime
SUPABASE_DB_URL=
WEB_APP_URL=http://localhost:3000

# Required for full production MVP behavior
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
BACKBOARD_API_KEY=
GOOGLE_GENAI_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Auth0 API verification (optional in local dev, required in production)
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_ISSUER=
APP_JWT_NAMESPACE=https://growthlaunchpad.app

# Optional flags
BACKBOARD_DEFAULT_MODEL=
ENABLE_VIDEO_RENDER=true
ENABLE_TOKEN_VAULT=false
WORKER_POLL_INTERVAL_SECONDS=3
